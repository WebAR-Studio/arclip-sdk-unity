--- !u!114 &8214563085055038598
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6963275778050585241}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 91a6e0d0a24744b89adcbcd3c4a17c38, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _isVisible: 1
  _valueText: {fileID: 6716575099842995960}
  _defaultValue: "\u041B\u0430\u043A\u043E\u043D\u0438\u0447\u043D\u044B\u0439 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431
    \u0434\u043B\u044F \u043C\u0443\u0436\u0447\u0438\u043D \u0438 \u0436\u0435\u043D\u0449\u0438\u043D.\n\n12
    STOREEZ \u2014 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0438\u0439 \u0431\u0440\u0435\u043D\u0434
    \u043E\u0434\u0435\u0436\u0434\u044B,\n\u0441\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u0439
    \u0441\u0435\u0441\u0442\u0440\u0430\u043C\u0438-\u0431\u043B\u0438\u0437\u043D\u0435\u0446\u0430\u043C\u0438
    \u0418\u0440\u0438\u043D\u043E\u0439 \u0438\n\u041C\u0430\u0440\u0438\u043D\u043E\u0439
    \u0413\u043E\u043B\u043E\u043C\u0430\u0437\u0434\u0438\u043D\u044B\u043C\u0438
    \u0438 \u0418\u0432\u0430\u043D\u043E\u043C\n\u0425\u043E\u0445\u043B\u043E\u0432\u044B\u043C.
    \u041A\u0430\u0436\u0434\u044B\u0439 \u0433\u043E\u0434 \u043C\u0430\u0440\u043A\u0430
    \u0432\u044B\u043F\u0443\u0441\u043A\u0430\u0435\u0442 12\n\u0438\u0441\u0442\u043E\u0440\u0438\u0439
    \u2014 12 \u043C\u0438\u043D\u0438-\u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u0439,
    \u0432\u0441\u0435 \u043C\u043E\u0434\u0435\u043B\u0438 \u0432\n\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u043E\u0447\u0435\u0442\u0430\u044E\u0442\u0441\u044F \u0434\u0440\u0443\u0433
    \u0441 \u0434\u0440\u0443\u0433\u043E\u043C.\n\u041D\u0430\u0448\u0430 \u0438\u0434\u0435\u044F
    \u2013 \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u043D\u044B\u0439
    \u0438\n\u043F\u0440\u043E\u0434\u0443\u043C\u0430\u043D\u043D\u044B\u0439 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431
    \u043D\u0430\u0434\u043E\u043B\u0433\u043E. \u0418 \u043E\u0431\u043D\u043E\u0432\u043B\u044F\u0442\u044C\n\u0435\u0433\u043E
    \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0432\u0435\u0449\u0430\u043C\u0438
    1-2 \u0440\u0430\u0437\u0430 \u0432 \u0441\u0435\u0437\u043E\u043D. \u041C\u044B\n\u0443\u0434\u0435\u043B\u044F\u0435\u043C
    \u043C\u043D\u043E\u0433\u043E \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F
    \u0432\u044B\u0431\u043E\u0440\u0443\n\u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0442\u043A\u0430\u043D\u0435\u0439 \u0438 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432
    \u0438\n\u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u0440\u043E\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u043C
    \u043A\u0430\u0436\u0434\u0443\u044E \u043C\u043E\u0434\u0435\u043B\u044C 12\nSTOREEZ:
    \u0447\u0435\u043C \u043B\u0430\u043A\u043E\u043D\u0438\u0447\u043D\u0435\u0435
    \u043A\u0440\u043E\u0439, \u0442\u0435\u043C \u0431\u043E\u043B\u0435\u0435 \u043C\u044B\n\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B
    \u043A \u0434\u0435\u0442\u0430\u043B\u044F\u043C."

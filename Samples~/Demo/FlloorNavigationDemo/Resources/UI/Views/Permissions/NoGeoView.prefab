    - target: {fileID: 940000, guid: 35e2b1736c954ec58a02804186eacbab, type: 3}
      propertyPath: _defaultDescriptionValue
      value: "\u0414\u043B\u044F \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0439
        \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044E

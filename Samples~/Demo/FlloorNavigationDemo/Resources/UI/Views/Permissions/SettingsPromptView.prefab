    _iconSprite: {fileID: 0}
    _iconValue: "\u26A0"
    _titleValue: "\u041D\u0435\u0442 \u043F\u043E\u0434\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
      \u043A \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442\u0443"
    _descriptionValue: "\u0414\u043B\u044F \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0439
      \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044E

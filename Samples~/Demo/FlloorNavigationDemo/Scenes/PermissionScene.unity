    - target: {fileID: 5074736668540295655, guid: 021da114fe8443b49a7bd9f100a77de0, type: 3}
      propertyPath: m_Text
      value: "\u0414\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F

      objectReference: {fileID: 21300000, guid: 687d651b90af874428cd7e5dcd46b442, type: 3}
    - target: {fileID: 940000, guid: 35e2b1736c954ec58a02804186eacbab, type: 3}
      propertyPath: _variants.Array.data[2]._titleValue
      value: "\u0414\u043E\u0441\u0442\u0443\u043F \u043A \u043A\u0430\u043C\u0435\u0440\u0435"
      objectReference: {fileID: 0}
    - target: {fileID: 940000, guid: 35e2b1736c954ec58a02804186eacbab, type: 3}
      propertyPath: _variants.Array.data[0]._buttonValue
      value: "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"

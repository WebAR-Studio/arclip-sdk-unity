    - target: {fileID: 940000, guid: 35e2b1736c954ec58a02804186eacbab, type: 3}
      propertyPath: _variants.Array.data[1]._buttonValue
      value: "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"
      objectReference: {fileID: 0}
    - target: {fileID: 940000, guid: 35e2b1736c954ec58a02804186eacbab, type: 3}
      propertyPath: _variants.Array.data[2]._buttonValue
      value: "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"
      objectReference: {fileID: 0}
    - target: {fileID: 940000, guid: 35e2b1736c954ec58a02804186eacbab, type: 3}
      propertyPath: _variants.Array.data[1]._descriptionValue
      value: "\u0414\u043B\u044F \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0439
        \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044E
        \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435
        \u043D\u0430 \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u0432\u0430\u0448\u0435\u0439
        \u0433\u0435\u043E\u043F\u043E\u0437\u0438\u0446\u0438\u0438. \u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
        \u0432\u043A\u043B\u044E\u0447\u0438\u0442\u0435 GPS \u0432 \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430\u0445
        \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430"
      objectReference: {fileID: 0}
    - target: {fileID: 940000, guid: 35e2b1736c954ec58a02804186eacbab, type: 3}
      propertyPath: _variants.Array.data[2]._descriptionValue
      value: "\u0414\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F
        \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435
        \u043D\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
        \u043A\u0430\u043C\u0435\u0440\u044B. \u042D\u0442\u043E \u043D\u0443\u0436\u043D\u043E,
        \u0447\u0442\u043E\u0431\u044B \u0441\u043A\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u0442\u044C
        \u043E\u0431\u044A\u0435\u043A\u0442\u044B \u0438 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u0442\u044C
        \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u043E\u0439
        \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438."
      objectReference: {fileID: 0}
